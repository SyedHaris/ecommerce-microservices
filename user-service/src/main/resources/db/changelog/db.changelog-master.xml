<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260620-create-user-table" author="haris">
        <createTable tableName="user">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="username" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260620-add-admin-user" author="haris">
        <insert tableName="user">
            <column name="username" value="Admin"/>
            <column name="email" value="admin@test.com"/>
            <column name="password" value="$2a$10$O/zBPtcCDDn1u/JLtd.XvOrmxJekkpW14CV3X6tm1yeDaR9dLLPIe"/>
            <column name="role" value="ADMIN"/>
        </insert>
    </changeSet>

</databaseChangeLog>